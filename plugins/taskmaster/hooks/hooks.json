{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/remind.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ultra.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ultra-goal.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Artifact",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/preview-guard.sh" }
        ]
      }
    ]
  }
}
